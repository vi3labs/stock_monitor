# Stock Monitor Environment Variables
# ====================================
# Copy this file to .env and fill in your values
# Then run: source .env (or use python-dotenv)

# Notion API Token (required for Notion watchlist sync)
# Get yours at: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_your_token_here

# Optional: Override the default Notion database ID
# NOTION_DATABASE_ID=your-database-id-here

# API key for dashboard write operations (POST/PATCH/DELETE on /api/watchlist)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_API_KEY=
